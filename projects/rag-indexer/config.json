{
  "roots": [
    "./example-docs"
  ],
  "excludes": [
    ".git",
    "node_modules",
    ".venv",
    "venv",
    "vendor",
    "chroma",
    "__pycache__",
    ".DS_Store",
    "dist",
    "build",
    ".next",
    "coverage"
  ],
  "include_only": {
    "filenames": ["README.md"],
    "path_contains": ["/docs/"]
  },
  "extensions": [".md", ".json"],
  "max_file_size_kb": 1024,
  "chunk_size": 500,
  "chunk_overlap": 50,
  "embed_model": "nomic-embed-text",
  "embed_parallel": 4,
  "ollama_url": "http://localhost:11434",
  "chroma_path": "./chroma",
  "collection": "docs"
}
